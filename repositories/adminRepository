// repositories/adminRepository.js
const fs = require('fs');
const path = require('path');

const dataFilePath = path.join(__dirname, '../data/courses.json');
const bookingsFilePath = path.join(__dirname, '../data/bookings.json');

// Arrays als zentrale Datenquellen zur Laufzeit
let courseArray = [];
let bookingArray = [];

try {
    if (!fs.existsSync(path.dirname(dataFilePath))) {
        fs.mkdirSync(path.dirname(dataFilePath), { recursive: true });
    }
    // Vorhandene Kurse aus der JSON laden
    if (fs.existsSync(dataFilePath)) {
        courseArray = JSON.parse(fs.readFileSync(dataFilePath, 'utf-8') || '[]');
    }
} catch (e) {
    console.log("courses.json fehlt oder ist ungültig: Datei wird neu angelegt");
    fs.writeFileSync(dataFilePath, JSON.stringify(courseArray, null, 4), 'utf-8');
}

try {
    // Vorhandene Buchungen aus der JSON laden
    if (fs.existsSync(bookingsFilePath)) {
        bookingArray = JSON.parse(fs.readFileSync(bookingsFilePath, 'utf-8') || '[]');
    }
} catch (e) {
    console.log("bookings.json fehlt oder ist ungültig: Datei wird neu angelegt");
    fs.writeFileSync(bookingsFilePath, JSON.stringify(bookingArray, null, 4), 'utf-8');
}


const saveData = () => {
    // Array nach ID sortieren, damit es bei Updates nicht durcheinander kommt
    courseArray.sort((a, b) => a.id.localeCompare(b.id));
    fs.writeFileSync(dataFilePath, JSON.stringify(courseArray, null, 4), 'utf-8');
};

const runAutoLogic = () => {
    const today = new Date().toISOString().split('T')[0];

    courseArray = courseArray.map(course => {
        // (Partner = +2, Einzel = +1)
        const kursBuchungen = bookingArray.filter(b => b.courseId === course.id);
        let echteTeilnehmerAnzahl = 0;
        kursBuchungen.forEach(b => {
            if (b.partnerName && b.partnerName.trim() !== '') {
                echteTeilnehmerAnzahl += 2;
            } else {
                echteTeilnehmerAnzahl += 1;
            }
        });
        course.bookedParticipants = echteTeilnehmerAnzahl;

        // (Datum abgelaufen -> inaktiv)
        if (course.startDate < today && course.status === 'active') {
            course.status = 'inactive';
        }

        return course;
    });
    saveData();
};

// Liefert alle Buchungen für die untere Tabelle
const getAllBookings = () => {
    return bookingArray;
};

// Sucht einen einzelnen Kurs über seine ID
const getCourse = (id) => {
    return courseArray.find(c => c.id === id);
};

// Erstellt einen neuen Kurs und generiert die ID  
const createCourse = (data) => {
    const styleSlug = data.style ? data.style.trim().toLowerCase().replace(/[^a-z0-9]/g, '') : 'kurs';
    
    const anzahlGleicherStil = courseArray.filter(c => {
        const cSlug = c.style ? c.style.trim().toLowerCase().replace(/[^a-z0-9]/g, '') : 'kurs';
        return cSlug === styleSlug;
    }).length;

    // Startet sauber bei 101 für den jeweiligen Stil (z.B. salsa-104, weil es schon 3 Salsa-Kurse gibt)
    const newId = `${styleSlug}-${101 + anzahlGleicherStil}`;

    const newCourse = {
        id: newId, // Verwendet die korrekte, stil-spezifische ID
        name: data.name,
        style: data.style,
        level: data.level,
        ageGroup: data.ageGroup,
        weekday: data.weekday,
        time: data.time,
        startDate: data.startDate,
        maxParticipants: parseInt(data.maxParticipants) || 0,
        bookedParticipants: 0,
        status: "active"
    };

    courseArray.push(newCourse);
    saveData();
    return newCourse;
};

// Aktualisiert einen bestehenden Kurs
const updateCourse = (id, data) => {
    const index = courseArray.findIndex(c => c.id === id);

    if (index !== -1) {
        const changedCourse = {
            ...courseArray[index], // Behält die ID und sonstige nicht-Formularfelder bei
            name: data.name,
            style: data.style,
            level: data.level,
            ageGroup: data.ageGroup,
            weekday: data.weekday,
            time: data.time,
            startDate: data.startDate,
            maxParticipants: parseInt(data.maxParticipants) || 0,
            status: data.status
        };

        courseArray[index] = changedCourse;
        saveData();
        runAutoLogic(); // Rechnet Teilnehmerzahlen sofort neu durch
        return { data: changedCourse, isNew: false };
    } else {
        return { data: createCourse(data), isNew: true };
    }
};


module.exports = {
    getAllBookings,
    getCourse,
    createCourse,
    updateCourse
};
