<!DOCTYPE html>
<html lang="de"> 

<%- include('partials/head') %>
<body>
  <%- include('partials/header') %>
  <main>
    <section class="hero">
      <div class="container">
        <h1>Tanzen. Erleben. Verbinden.</h1>
        <p>Finde deinen Rhythmus in Wiesbaden. Entdecke unsere Tanzkurse.</p>
        <a href="/courses" class="btn btn-primary">Jetzt Kurse ansehen</a>
      </div>
    </section>

    <section class="features">
      <div class="container features-grid">
        <div class="feature-card">
          <h3>Top Trainer</h3>
          <p>Lerne von den erfahrensten Tanzlehrern.</p>
        </div>
        <div class="feature-card">
          <h3>Alle Level</h3>
          <p>Von Anfänger bis Masterclass.</p>
        </div>
        <div class="feature-card">
          <h3>Community</h3>
          <p>Werde Teil unserer Tanzfamilie.</p>
        </div>
      </div>
    </section>
  </main>

  <section class="container py-5 my-4 border-top" id="kontakt">
    <div class="row">
      
      <div class="col-md-6 mb-4 mb-md-0">
        <h3>DanceFlow Wiesbaden</h3>
        <p>Deine Tanzschule in Wiesbaden – für Anfänger bis Fortgeschrittene.</p>
        <p style="margin-top: 1rem;"><strong>Adresse:</strong> Musterstraße 12, 65183 Wiesbaden</p>
        <p><strong>E-Mail:</strong> kontakt@danceflow-wiesbaden.de</p>
      </div>

      <div class="col-md-6">
        <h3>Schreib uns</h3>
        <form class="contact-form" action="/api/contact" method="POST">
          <input type="text" name="name" placeholder="Dein Name" class="form-control mb-3" required>
          <input type="email" name="email" placeholder="Deine E-Mail-Adresse" class="form-control mb-3" required>
          <textarea name="message" placeholder="Deine Nachricht" class="form-control mb-3" required></textarea>
          <button type="submit" class="btn btn-primary">Nachricht senden</button>
        </form>
      </div>

    </div>
  </section>

  <%- include('partials/footer') %>

</body>
</html>
