<nav class="navbar navbar-expand-md navbar-dark site-header py-3">
  <div class="container position-relative justify-content-center justify-content-md-between">
    
    <a class="navbar-brand mx-auto mx-md-0 p-0 text-center" href="/">
      <img src="/images/logo_danceflow_wiesbaden.png" alt="Danceflow Wiesbaden Logo" height="100">
    </a>

    <button class="navbar-toggler position-absolute end-0 top-50 translate-middle-y me-3" type="button" data-bs-toggle="collapse" data-bs-target="#danceflowNavbar" aria-controls="danceflowNavbar" aria-expanded="false" aria-label="Navigation umschalten">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="danceflowNavbar">
      
      <ul class="navbar-nav mx-auto my-3 my-md-0 gap-3 text-center">
        <li class="nav-item">
          <a href="/" class="btn-secondary nav-link d-inline-block px-3">Home</a>
        </li>
        <li class="nav-item">
          <a href="/courses" class="btn-secondary nav-link d-inline-block px-3">Kurse</a>
        </li>
        <li class="nav-item">
          <a href="/#kontakt" class="btn-secondary nav-link d-inline-block px-3">Kontakt</a>
        </li>
      </ul>
      
      <div class="d-flex justify-content-center justify-content-md-end align-items-center gap-3 mt-2 mt-md-0">
        <% if (user) { %>
          <% if (user.role==='admin' ) { %>
            <a href="/admin" class="btn btn-outline-light">Dashboard</a>
          <% } %>
