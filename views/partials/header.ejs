<div class="site-header" style="position: relative; background: #191970;">
  <div class="container">
    <header class="d-flex flex-wrap align-items-center justify-content-center justify-content-md-between py-2">

      <div class="col-md-3 mb-2 mb-md-0">
        <a href="/" class="d-inline-flex link-body-emphasis text-decoration-none">
          <img src="../images/logo_danceflow_wiesbaden.png" alt="Danceflow Wiesbaden Logo" height="50">
        </a>
      </div>

      <ul class="nav col-12 col-md-auto mb-2 justify-content-center mb-md-0">
        <li><a href="/" class="nav-link px-2 text-white">Home</a></li>
        <li><a href="/courses" class="nav-link px-2 text-white">Kurse</a></li>
        <li><a href="/#kontakt" class="nav-link px-2 text-white">Kontakt</a></li>
      </ul>

      <div class="col-md-3 text-end d-flex justify-content-end align-items-center gap-2">
        <% if (user) { %>
          <% if (user.role==='admin' ) { %>
            <a href="/admin" class="nav-link px-2 text-white">Dashboard</a>
            <% } %>
              <a href="#" onclick="logout()" class="nav-link px-2 text-white">Logout</a>
              <% } else { %>
                <a href="/login" class="nav-link px-2 text-white">Login</a>
                <% } %>
      </div>

    </header>
  </div>
</div>

<!-- JS für Logout -->

<script>
  async function logout() {
    const response = await fetch('/api/auth/logout', { method: 'POST' });
    const data = await response.json();
    if (data.success) window.location.href = '/';
  }
</script>