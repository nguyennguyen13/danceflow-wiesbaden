<!DOCTYPE html>
<html lang="de">

<head><%- include('partials/head') %>
        <title>
            <%= course.name %> | DanceFlow Wiesbaden
        </title>
</head>

<body class="courses-page">
    <%- include('partials/header') %>
        <main class="course-detail container">
            <a class="back-link" href="/courses">← Alle Kurse</a>
            <div class="course-detail__grid">
                <section>
                    <p class="eyebrow">
                        <%= course.style %> · <%= course.level %>
                    </p>
                    <h1>
                        <%= course.name %>
                    </h1>
                    <p class="course-detail__lead">Starte am <strong>
                            <%= new Date(course.startDate + 'T00:00:00' ).toLocaleDateString('de-DE') %>
                        </strong> und tanze jeden <strong>
                            <%= course.weekday %>
                        </strong> von <strong>
                            <%= course.time %>
                        </strong>.</p>
                    <div class="detail-facts"><span><strong>Level</strong>
                            <%= course.level %>
                        </span><span><strong>Altersgruppe</strong>
                            <%= course.ageGroup %>
                        </span><span><strong>Freie Plätze</strong>
                            <%= course.availablePlaces %> von <%= course.maxParticipants %>
                        </span></div>
                </section>
                <section class="booking-panel">
                    <h2>Jetzt anmelden</h2>

                    <% if (!user) { %>
                        <!-- Noch nicht eingeloggt -->
                        <div class="booking-guest-hint">
                            <p>Sie müssen eingeloggt sein, um diesen Kurs zu buchen.</p>
                            <a href="/login" class="btn btn-primary">Zum Login</a>
                        </div>
                        <% } else { %>
                            <form id="bookingForm">
                                <input type="hidden" id="courseId" value="<%= course.id %>">
                                <input type="hidden" id="customerName" value="<%= user.name %>">
                                <input type="hidden" id="email" value="<%= user.email %>">

                                <label>
                                    Dein Name: 
                                    <input type="text" id="participantName" value="<%= user.name %>" required>
                                </label>

                                <div class="checkbox-group">
                                    <input type="checkbox" id="isPartner">
                                    <label for="isPartner">Mit Tanzpartner buchen</label>
                                    <small>(2 Plätze werden reserviert)</small>
                                </div>

                                <div id="partnerField" style="display: none;">
                                    <label>
                                        Name des Partners:
                                        <input type="text" id="partnerName">
                                    </label>
                                </div>

                                <% if (course.isFull) { %>
                                    <p class="booking-hint"
                                        style="background: #fff8e6; padding: 0.8rem; border-radius: 6px;">
                                        Dieser Kurs ist ausgebucht. Sie können sich auf die
                                        <strong>Warteliste</strong> setzen.
                                    </p>
                                    <button type="submit" class="btn btn-warning">Auf Warteliste setzen</button>
                                    <% } else { %>
                                        <p class="booking-hint">
                                            Bei Überbuchung werden Sie automatisch auf die Warteliste gesetzt.
                                        </p>
                                        <button type="submit" class="btn btn-primary">Verbindlich buchen</button>
                                        <% } %>

                                            <div id="bookingError" class="form-error" style="display: none;"></div>
                            </form>
                            <% } %>
                </section>

            </div>
        </main>
        <%- include('partials/footer') %>
            <script>
                const user = <%- user ? JSON.stringify(user) : 'null' %>;
            </script>
            <script src="/js/booking.js"></script>

            <script>
                document.addEventListener('DOMContentLoaded', function () {
                    const isPartnerCheckbox = document.getElementById('isPartner');
                    const partnerField = document.getElementById('partnerField');

                    if (isPartnerCheckbox) {
                        isPartnerCheckbox.addEventListener('change', function () {
                            partnerField.style.display = this.checked ? 'block' : 'none';
                            if (!this.checked) {
                                document.getElementById('partnerName').value = '';
                            }
                        });
                    }
                });
            </script>
</body>

</html>