<!DOCTYPE html>
<html lang="de">

<head><%- include('partials/head') %>
        <title>
            <%= course.name %> | DanceFlow Wiesbaden
        </title>
</head>

<body class="courses-page">
    <%- include('partials/header') %>
        <main class="course-detail container">
            <a class="back-link" href="/courses">← Alle Kurse</a>
            <div class="course-detail__grid">
                <section>
                    <p class="eyebrow">
                        <%= course.style %> · <%= course.level %>
                    </p>
                    <h1>
                        <%= course.name %>
                    </h1>
                    <p class="course-detail__lead">Starte am <strong>
                            <%= new Date(course.startDate + 'T00:00:00' ).toLocaleDateString('de-DE') %>
                        </strong> und tanze jeden <strong>
                            <%= course.weekday %>
                        </strong> von <strong>
                            <%= course.time %>
                        </strong>.</p>
                    <div class="detail-facts"><span><strong>Level</strong>
                            <%= course.level %>
                        </span><span><strong>Altersgruppe</strong>
                            <%= course.ageGroup %>
                        </span><span><strong>Freie Plätze</strong>
                            <%= course.availablePlaces %> von <%= course.maxParticipants %>
                        </span></div>
                </section>
                <section class="booking-panel">
                    <h2>Jetzt anmelden</h2>
                    <% if (course.isFull) { %>
                        <p>Dieser Kurs ist aktuell ausgebucht.</p>
                        <% } else { %>
                            <% if (error) { %>
                                <p class="form-error" role="alert">
                                    <%= error %>
                                </p>
                                <% } %>
                                    <form action="/courses/<%= course.id %>/book" method="post">
                                        <label>Dein Name *<input name="customerName" required
                                                value="<%= form?.customerName || '' %>"></label>
                                        <label>E-Mail-Adresse *<input type="email" name="email" required
                                                value="<%= form.email || '' %>"></label>
                                        <label>Name der Tanzpartnerin / des Tanzpartners <small>(optional)</small><input
                                                name="partnerName" value="<%= form.partnerName || '' %>"></label>
                                        <p class="booking-hint">Mit Partner*in werden zwei Plätze reserviert.</p>
                                        <button class="btn btn-primary" type="submit">Verbindlich buchen</button>
                                    </form>
                                    <% } %>
                </section>
            </div>
        </main>
        <%- include('partials/footer') %>
            <script>
                const user = <%- user ? JSON.stringify(user) : 'null' %>;
            </script>
            <script src="/js/booking.js"></script>
</body>

</html>