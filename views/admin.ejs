<!DOCTYPE html>
<html lang="de"> 
    <%- include('partials/head') %>
<body class="bg-light">    
    <!-- Header/Navbar wieder aktivieren -->
    <%- include('partials/header') %>

    <!-- mt-5 und pt-5 sorgt für genug Abstand unter dem Header -->
    <main class="container" style="margin-top: 150px; position: relative; z-index: 1050;">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1>Kurs-Verwaltung (Admin)</h1>
            <!-- Dieser Button führt zum Formular -->
            <a href="/admin/new-course" class="btn btn-primary d-flex align-items-center">
                <span class="fs-4 me-2">+</span> Neuen Kurs anlegen
            </a>
        </div>

        <!-- Tabelle der Kurse -->
        <% if (courses && courses.length > 0) { %>
            <div class="table-responsive bg-white shadow-sm rounded border">
                <table class="table table-hover table-striped align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Datum</th>
                            <th>Kursname</th>
                            <th>Stil</th>
                            <th>Level</th>
                            <th>Tag & Uhrzeit</th>
                            <th>Teilnehmer</th>
                            <th>Status</th>
                            <!-- Spaltenkopf für die Aktion -->
                            <th>Aktion</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% courses.forEach(course => { %>
                            <tr>
                                <td><code class="text-secondary"><%= course.startDate %></code></td>
                                <td><strong><%= course.name %></strong></td>
                                <td><span class="badge bg-secondary"><%= course.style %></span></td>
                                <td><span class="text-capitalize"><%= course.level %></span></td>
                                <td><%= course.weekday %>, <%= course.time %></td>
                                <td>
                                    <%= course.bookedParticipants %> / <%= course.maxParticipants %>
                                    <div class="progress mt-1" style="height: 5px;">
                                        <% let percent = (course.bookedParticipants / course.maxParticipants) * 100; %>
                                        <div class="progress-bar bg-success" ></div>
                                    </div>
                                </td>
                                <td>
                                    <% if (course.status === 'active') { %>
                                        <span class="badge bg-success">Aktiv</span>
                                    <% } else { %>
                                        <span class="badge bg-danger">Inaktiv</span>
                                    <% } %>
                                </td>
                                <!-- Nur noch der Bearbeiten-Button -->
                                <td>
                                    <!-- Ruft das Formular im Bearbeitungsmodus auf -->
                                    <a href="/admin/edit-course/<%= course.id %>" class="btn btn-sm btn-warning">
                                        Bearbeiten
                                    </a>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        <% } else { %>
            <div class="alert alert-info shadow-sm">
                Keine Kurse gefunden. Klicken Sie oben auf den Button, um den ersten Kurs anzulegen!
            </div>
        <% } %>
        <!-- Abschnitt für Kunden-Buchungen -->
<div class="mt-5 mb-5" style="position: relative; z-index: 1050;">
    <h2 class="mb-4">Eingegangene Kurs-Buchungen</h2>
    
    <% if (bookings && bookings.length > 0) { %>
        <div class="table-responsive bg-white shadow-sm rounded border">
            <table class="table table-hover table-striped align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Buchungs-ID</th>
                        <th>Kunde</th>
                        <th>Tanzpartner</th>
                        <th>Gebuchter Kurs</th>
                        <th>Status</th>
                        <th>Eingegangen am</th>
                    </tr>
                </thead>
                <tbody>
                    <% bookings.forEach(booking => { %>
                        <!-- Kursnamen live über die courseId aus dem courses-Array ermitteln -->
                        <% 
                            let matchingCourse = courses.find(c => c.id === booking.courseId);
                            let courseDisplayName = matchingCourse ? matchingCourse.name : 'Unbekannter Kurs (' + booking.courseId + ')';
                        %>
                        <tr>
                            <td><code class="text-secondary"><%= booking.id %></code></td>
                            <td><strong><%= booking.customerName %></strong></td>
                            <td>
                                <% if (booking.partnerName && booking.partnerName.trim() !== '') { %>
                                    <%= booking.partnerName %>
                                <% } else { %>
                                    <span class="text-muted"><em>Einzelanmeldung</em></span>
                                <% } %>
                            </td>
                            <td>
                                <span class="badge bg-info text-dark"><%= courseDisplayName %></span>
                            </td>
                            <td>
                                <% if (booking.status === 'confirmed') { %>
                                    <span class="badge bg-success">Bestätigt</span>
                                <% } else { %>
                                    <span class="badge bg-warning text-dark"><%= booking.status %></span>
                                <% } %>
                            </td>
                            <td><%= booking.createdAt %></td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    <% } else { %>
        <div class="alert alert-info shadow-sm">
            Bisher liegen noch keine Kurs-Buchungen vor.
        </div>
    <% } %>
</div>

    </main>

    <%- include('partials/footer') %>
</body>
</html>
